{
  "UUID": "me.harke.better-audio-mixer",
  "SDKVersion": 2,
  "Author": "Harke Webdesign",
  "Name": "Better Audio Mixer",
  "Description": "Remote control for the Better Audio Mixer per-app audio mixer.",
  "URL": "https://github.com/lkshrk/better-audio-mixer",
  "Category": "Better Audio Mixer",
  "CategoryIcon": "icons/category",
  "Icon": "icons/pluginIcon",
  "Version": "0.9.7.0",
  "CodePath": "bin/BAMStreamDeck",
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Actions": [
    {
      "UUID": "me.harke.better-audio-mixer.streamdeck.device",
      "Name": "Device",
      "Icon": "icons/device",
      "Tooltip": "Mute, adjust, or set a device — on a key or a dial.",
      "PropertyInspectorPath": "pi/device.html",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/band.json",
        "TriggerDescription": {
          "Rotate": "Adjust volume",
          "Push": "Mute"
        }
      },
      "States": [
        {
          "Image": "icons/key",
          "TitleAlignment": "bottom"
        },
        {
          "Image": "icons/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "UUID": "me.harke.better-audio-mixer.streamdeck.master",
      "Name": "Master",
      "Icon": "icons/masterVolume",
      "Tooltip": "Mute, adjust, or set the master — on a key or a dial.",
      "PropertyInspectorPath": "pi/master.html",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/band.json",
        "TriggerDescription": {
          "Rotate": "Adjust master",
          "Push": "Mute"
        }
      },
      "States": [
        {
          "Image": "icons/key",
          "TitleAlignment": "bottom"
        },
        {
          "Image": "icons/key",
          "TitleAlignment": "bottom"
        }
      ]
    },
    {
      "UUID": "me.harke.better-audio-mixer.streamdeck.output",
      "Name": "Output Device",
      "Icon": "icons/output",
      "Tooltip": "Set or toggle the bam hardware output device.",
      "PropertyInspectorPath": "pi/output.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "icons/key",
          "TitleAlignment": "middle"
        }
      ]
    }
  ]
}